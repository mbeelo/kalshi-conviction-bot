# Kalshi API Configuration
# Get these from your Kalshi account settings

# Your Kalshi API Key ID
KALSHI_API_KEY_ID=your_api_key_id_here

# Path to your private key file (download from Kalshi)
KALSHI_PRIVATE_KEY_PATH=/path/to/your/kalshi_private_key.pem

# Set to 'true' for demo mode, 'false' for live trading
KALSHI_DEMO=true

# Optional: Override default configuration
# CONTRACT_QUANTITY=10
# YES_BUY_THRESHOLD=0.94
# NO_BUY_THRESHOLD=0.06